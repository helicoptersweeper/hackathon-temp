<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.simplecss.org/simple.min.css">
    <title>Weather App</title>
</head>

<body
    style="background: url('https://t3.ftcdn.net/jpg/06/37/91/58/360_F_637915894_xioRfH3tMwJ7EopQqoGCe5dkzjPYMJLx.jpg') no-repeat center center fixed; background-size: cover;">
    <center>
        <header>
            <h1 style="color:white;font-family:Georgia">Weather App</h1>
            <p style="color:white" ;>Your window to the world’s weather. Enter a city to get real-time updates and stay
                ahead of the elements.</p>
        </header>
        <br>
        <main>
            <form action="/weather" method="POST">
                <fieldset style="border-color: black; border-width: 2px;">
                    <legend style="color: black;">Weather Forecast</legend>
                    <input type="text" placeholder="enter name of city" id="cityname" name="cityname" required autocomplete="off">
                    <br>
                    <button type="submit">Submit</button>
                </fieldset>
            </form>

            <% if (error) { %>
            <p style="color: red;">
                <%= error %>
            </p>
            <% } %>

            <% if (weather) { %>
            <article style="color: black; border-width: 2px; border-color: black;">
                <h2>Weather in <%= weather.city %>
                </h2>
                <p><strong>Condition:</strong>
                    <%= weather.description %>
                </p>
                <p><strong>Temperature:</strong>
                    <%= weather.temp %>°C (feels like <%= weather.feels_like %>°C)
                </p>
                <p><strong>Humidity:</strong>
                    <%= weather.humidity %>%
                </p>
                <p><strong>Wind Speed:</strong>
                    <%= weather.wind %> m/s
                </p>
            </article>
            <% } %>

        </main>
    </center>
</body>

</html>
