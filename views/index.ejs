<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.simplecss.org/simple.min.css">
    <title>Weather App</title>
</head>

<body>
    <center>
        <header>
            <h1>Weather App</h1>
        </header>
        <br>
        <main>
            <form action="/weather" method="POST">
                <fieldset>
                    <legend>Weather Forecast</legend>
                    <input type="text" placeholder="enter name of city" id="cityname" name="cityname" required>
                    <br>
                    <button type="submit">Submit</button>
                </fieldset>
            </form>

            <% if (error) { %>
                <p style="color: red;">
                    <%= error %>
                </p>
                <% } %>

                    <% if (weather) { %>
                        <article>
                            <h2>Weather in <%= weather.city %>
                            </h2>
                            <p><strong>Condition:</strong>
                                <%= weather.description %>
                            </p>
                            <p><strong>Temperature:</strong>
                                <%= weather.temp %>°C (feels like <%= weather.feels_like %>°C)
                            </p>
                            <p><strong>Humidity:</strong>
                                <%= weather.humidity %>%
                            </p>
                            <p><strong>Wind Speed:</strong>
                                <%= weather.wind %> m/s
                            </p>
                        </article>
                        <% } %>

        </main>
    </center>
</body>

</html>